rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: schedules/{date}/results
    // Document ID: cidade
    // Fields:
    //   - cidade: string (required)
    //   - motorista: string (required)
    //   - status: string (required)
    //   - coordenador: string (required)
    //   - kmInicial: number (required)
    //   - kmFinal: number (required)
    //
    // Collection: schedules/{date}/observacoes
    // Document ID: cidade
    // Fields:
    //   - text: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "dionisioporto16@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['cidade']) &&
             data.cidade is string && data.cidade.size() > 0 && data.cidade.size() < 100 &&
             (!('motorista' in data) || data.motorista == null || (data.motorista is string && data.motorista.size() < 100)) &&
             (!('status' in data) || data.status == null || (data.status is string && data.status.size() < 50)) &&
             (!('coordenador' in data) || data.coordenador == null || (data.coordenador is string && data.coordenador.size() < 100)) &&
             (!('isRede' in data) || data.isRede == null || data.isRede is bool) &&
             (!('intervaloOk' in data) || data.intervaloOk == null || data.intervaloOk is bool) &&
             (!('observacao' in data) || data.observacao == null || (data.observacao is string && data.observacao.size() < 1000)) &&
             (!('encontrado' in data) || data.encontrado == null || data.encontrado is bool) &&
             (!('kmInicial' in data) || data.kmInicial == null || data.kmInicial is number) &&
             (!('kmFinal' in data) || data.kmFinal == null || data.kmFinal is number);
    }

    function isPositive(data, field) {
      return data[field] is number && data[field] >= 0;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['cidade', 'motorista', 'status', 'coordenador', 'kmInicial', 'kmFinal']) &&
             data.cidade is string && data.cidade.size() > 0 && data.cidade.size() < 100 &&
             data.motorista is string && data.motorista.size() > 0 && data.motorista.size() < 100 &&
             data.status is string && data.status.size() > 0 && data.status.size() < 50 &&
             data.coordenador is string && data.coordenador.size() > 0 && data.coordenador.size() < 100 &&
             isPositive(data, 'kmInicial') &&
             isPositive(data, 'kmFinal');
    }

    function isValidObservacao(data) {
      return data.keys().hasAll(['text']) &&
             data.text is string && data.text.size() >= 0 && data.text.size() < 2000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['role', 'email']) &&
             data.role in ['admin', 'user'] &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100;
    }

    function isValidShiftItem(data) {
      return data.keys().hasAll(['section', 'createdAt']) &&
             data.section in ['fixed', 'daily', 'coverage', 'dateFunctions'] &&
             data.createdAt is string &&
             (!('analista' in data) || data.analista is string) &&
             (!('os' in data) || data.os is string) &&
             (!('descritivo' in data) || data.descritivo is string) &&
             (!('ciclo' in data) || data.ciclo is string) &&
             (!('turno' in data) || data.turno is string);
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'author', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true;
    }

    match /schedules/{date}/assignments/{cidade=**} {
      allow read, write: if true;
    }

    match /schedules/{date}/results/{cidade=**} {
      allow read, write: if true;
    }

    match /schedules/{date}/observacoes/{cidade=**} {
      allow read, write: if true;
    }

    match /schedules/{date}/shiftItems/{itemId=**} {
      allow read, write: if true;
    }

    match /schedules/{date}/shiftChat/{chatId=**} {
      allow read, write: if true;
    }
  }
}
